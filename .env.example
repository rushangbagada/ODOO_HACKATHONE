# Neon (serverless Postgres) — pooled connection, used by the running app
DATABASE_URL="postgresql://<user>:<password>@<neon-pooler-host>/<db>?sslmode=require&channel_binding=require"

# Neon — direct connection, used by Prisma Migrate (non-pooled session)
DIRECT_URL="postgresql://<user>:<password>@<neon-direct-host>/<db>?sslmode=require&channel_binding=require"

# Generate with: openssl rand -base64 32 (or any long random string)
JWT_SECRET="replace-with-a-long-random-secret"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# SMTP config for license-expiry reminder emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASSWORD="your-smtp-app-password"
SMTP_FROM="your-email@example.com"
